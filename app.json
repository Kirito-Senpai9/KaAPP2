{
  "expo": {
    "name": "KaAPP2",
    "slug": "KaAPP2",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "kaapp2",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kaapp2"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.kaapp2",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon.png"
        }
      ],
      "react-native-edge-to-edge",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "c02406f4-e8e8-4486-822e-6c1f07736102"
      }
    }
  }
}
